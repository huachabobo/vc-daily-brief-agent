<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.vc-agent.serve-feedback</string>

  <key>ProgramArguments</key>
  <array>
    <string>/path/to/vc-daily-brief-agent/.venv/bin/python</string>
    <string>/path/to/vc-daily-brief-agent/scripts/serve_feedback.py</string>
  </array>

  <key>WorkingDirectory</key>
  <string>/path/to/vc-daily-brief-agent</string>

  <key>EnvironmentVariables</key>
  <dict>
    <key>FEISHU_CALLBACK_MODE</key>
    <string>long_connection</string>
  </dict>

  <key>RunAtLoad</key>
  <true/>

  <key>KeepAlive</key>
  <true/>

  <key>StandardOutPath</key>
  <string>/path/to/vc-daily-brief-agent/logs/serve_feedback.out.log</string>

  <key>StandardErrorPath</key>
  <string>/path/to/vc-daily-brief-agent/logs/serve_feedback.err.log</string>
</dict>
</plist>
